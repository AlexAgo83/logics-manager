{
  "name": "cdx-logics-vscode",
  "displayName": "Logics Orchestrator",
  "description": "Visual orchestration for Logics workflows inside VS Code.",
  "version": "1.7.0",
  "publisher": "cdx-logics",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexAgo83/cdx-logics-vscode.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "logics",
          "title": "Logics",
          "icon": "media/logics.svg"
        }
      ]
    },
    "views": {
      "logics": [
        {
          "id": "logics.orchestrator",
          "name": "Orchestrator",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "logics.refresh",
        "title": "Logics: Refresh"
      },
      {
        "command": "logics.open",
        "title": "Logics: Open Item"
      },
      {
        "command": "logics.promote",
        "title": "Logics: Promote Item"
      },
      {
        "command": "logics.newRequest",
        "title": "Logics: New Request"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run lint:ts",
    "lint:ts": "tsc -p ./ --noEmit",
    "lint:logics": "python3 logics/skills/logics-doc-linter/scripts/logics_lint.py",
    "ci:check": "npm run compile && npm run lint && npm run test && npm run lint:logics && npm run package:ci",
    "dev": "npm run compile && code --extensionDevelopmentPath=.",
    "debug:webview": "node debug/webview/server.mjs",
    "package:ci": "npx @vscode/vsce package --out /tmp/cdx-logics-vscode-ci.vsix",
    "package": "npm run compile && npx @vscode/vsce package",
    "install:vsix": "npm run package && code --install-extension cdx-logics-vscode-$(node -p \"require('./package.json').version\").vsix --force"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.86.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  }
}
